generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─────────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────────

enum Gender {
  MALE
  FEMALE
  OTHER
  UNKNOWN
}

enum PersonKind {
  PERSON
  PET
}

enum RelationshipType {
  SPOUSE
  PARTNER
  SIBLING
}

// Tipo de relación parento-filial. Default: BIOLOGICAL.
// ADOPTIVE: adopción legal. STEP: padrastro/madrastra (cónyuge actual del
// padre/madre biológico, sin adopción formal). Útil para representar el
// vínculo afectivo en el árbol sin perder la verdad genética.
enum RelationKind {
  BIOLOGICAL
  ADOPTIVE
  STEP
}

enum UserRole {
  ADMIN
  MEMBER
}

enum UserScope {
  ADMIN
  FAMILY
  BRANCH
}

enum ContentType {
  STORY
  RECIPE
  OBJECT
  DIARY
  INTERVIEW
  SOURCE
}

enum Visibility {
  BRANCH
  FAMILY
  ADMIN
}

enum ConfidenceLevel {
  HIGH    // documento, registro oficial, foto fechada
  MEDIUM  // testimonio directo
  LOW     // recuerdo indirecto o incompleto
}

enum AccessEffect {
  ALLOW
  DENY
}

enum AccessPermission {
  VIEW_PERSON
  EDIT_PERSON
  VIEW_MEDIA
  VIEW_PRIVATE
  VIEW_CONTENT
}

enum ProposalStatus {
  PENDING
  APPROVED
  REJECTED
}

enum ClaimedRelation {
  SIBLING
  HALF_SIBLING
  UNCLE_AUNT
  GREAT_UNCLE_AUNT
  COUSIN
  NEPHEW_NIECE
  ANCESTOR
  EXTENDED_FAMILY
}

enum NotificationType {
  PROPOSAL_SUBMITTED
  PROPOSAL_APPROVED
  PROPOSAL_REJECTED
  NEW_PERSON_ADDED
  NEW_CONTENT_ADDED
  PERSON_UPDATED
  NEW_COMMENT
  SECURITY_ALERT
  NEW_REACTION
  MENTION_IN_COMMENT
}

// Tipos de reacciones — selección curada (no se ofrece toda la galería de
// emoji para mantener el UI limpio y los counts comparables).
enum ReactionType {
  HEART     // ❤️  default — "me gusta / me emociona"
  LAUGH     // 😄 "qué chistoso / buen recuerdo"
  WOW       // 😮 "no sabía"
  SAD       // 😢 "qué tristeza"
  PRAY      // 🙏 "en paz / honor"
}

// ─────────────────────────────────────────────
// FAMILY (tenant raíz)
// ─────────────────────────────────────────────

model Family {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  createdAt DateTime @default(now())

  persons        Person[]
  relationships  Relationship[]
  users          User[]
  content        Content[]
  media          Media[]
  importantLinks ImportantLink[]
  config         FamilyConfig?
  auditLogs      AuditLog[]
  managedUnits   ManagedFamilyUnit[]
  accessRules    AccessRule[]
  proposals         PersonUpdateProposal[]
  creationProposals PersonCreationProposal[]
  notifications     Notification[]
  comments          Comment[]
  reactions         Reaction[]
}

// ─────────────────────────────────────────────
// PERSON
// ─────────────────────────────────────────────

model Person {
  id         String    @id @default(cuid())
  familyId   String
  firstName  String
  middleName String?
  lastName   String
  birthSurname1 String?
  birthSurname2 String?
  birthDate  DateTime?
  deathDate  DateTime?
  birthPlace String?
  gender     Gender     @default(UNKNOWN)
  nodeKind   PersonKind @default(PERSON)
  bio        String?
  coverPhoto String?

  // ── Parentesco directo ────────────────────────────────────────────
  fatherId   String?
  motherId   String?
  // Tipo de vínculo. Null = legacy (asume BIOLOGICAL). Las nuevas filas
  // deben llenar estos campos si fatherId/motherId no es null.
  fatherKind RelationKind?
  motherKind RelationKind?

  // ── Familia central (solo admin puede editar) ─────────────────────
  isCore     Boolean  @default(false)

  // ── Afiliación a unidad cuando los padres son desconocidos ────────
  unitAffiliationId   String?
  claimedRelation     ClaimedRelation?
  claimedRelationOfId String?

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  // ── Soft delete ────────────────────────────────────────────────────
  // Cuando deletedAt no es null, la persona es invisible al árbol y a las
  // queries de listado, pero sigue en DB para poder restaurar. Las
  // referencias (fatherId, motherId) NO se rompen — siguen apuntando a
  // este ID; el render del árbol simplemente filtra antes de pasarlo a
  // computeTreeLayout.
  deletedAt   DateTime?
  deletedById String?

  // ── Relaciones Prisma ─────────────────────────────────────────────
  family               Family          @relation(fields: [familyId], references: [id])

  // padre/madre → referencia a otra Person
  father               Person?         @relation("ChildFather", fields: [fatherId], references: [id])
  mother               Person?         @relation("ChildMother", fields: [motherId], references: [id])

  // hijos donde esta persona es el padre o la madre
  childrenAsFather     Person[]        @relation("ChildFather")
  childrenAsMother     Person[]        @relation("ChildMother")

  // Relaciones explícitas (solo SPOUSE / PARTNER — no PARENT_CHILD)
  person1Relations     Relationship[]  @relation("Person1")
  person2Relations     Relationship[]  @relation("Person2")

  user                 User?
  content              Content[]
  media                Media[]
  importantLinks       ImportantLink[] @relation("PersonLinks")
  importantLinkTargets ImportantLink[] @relation("ImportantLinkTarget")
  managedUnitsAsParentA ManagedFamilyUnit[] @relation("ManagedUnitParentA")
  managedUnitsAsParentB ManagedFamilyUnit[] @relation("ManagedUnitParentB")
  accessRules           AccessRule[]        @relation("AccessRuleTargetPerson")
  unitAffiliation       ManagedFamilyUnit?  @relation("PersonUnitAffiliation", fields: [unitAffiliationId], references: [id])
  claimedRelationOf     Person?             @relation("ClaimedRelationOf", fields: [claimedRelationOfId], references: [id])
  claimedRelationRefs   Person[]            @relation("ClaimedRelationOf")
  proposals                  PersonUpdateProposal[]    @relation("ProposalPerson")
  creationProposalsAsFather  PersonCreationProposal[]  @relation("CreationProposalFather")
  creationProposalsAsMother  PersonCreationProposal[]  @relation("CreationProposalMother")
}

// ─────────────────────────────────────────────
// RELATIONSHIP (solo parejas explícitas)
// El árbol genealógico usa fatherId/motherId en Person.
// Esta tabla guarda solo vínculos de pareja formales (SPOUSE/PARTNER).
// ─────────────────────────────────────────────

model Relationship {
  id        String           @id @default(cuid())
  familyId  String
  person1Id String
  person2Id String
  type      RelationshipType
  // Para SPOUSE/PARTNER: fecha real de matrimonio o inicio de la pareja
  // (NO la fecha en que se registró en el sistema). Null si no se conoce.
  // Para SIBLING: no aplica (los hermanos lo son desde siempre).
  startDate DateTime?
  endDate   DateTime?
  // createdAt es la fecha de registro en el sistema, NO de matrimonio.
  // Usado solo para audit / orden de inserción.
  createdAt DateTime         @default(now())

  family  Family @relation(fields: [familyId], references: [id])
  person1 Person @relation("Person1", fields: [person1Id], references: [id])
  person2 Person @relation("Person2", fields: [person2Id], references: [id])

  @@unique([person1Id, person2Id, type])
}

// ─────────────────────────────────────────────
// USER
// ─────────────────────────────────────────────

model User {
  id              String    @id @default(cuid())
  username        String    @unique
  passwordHash    String
  name            String
  familyId        String
  personId        String?   @unique
  role            UserRole  @default(MEMBER)
  scope           UserScope @default(FAMILY)
  branchRootId    String?   // para scope BRANCH: ID de la persona raíz de su subárbol
  // JTI del token de invitación usado para crear esta cuenta (single-use enforcement)
  inviteTokenJti  String?   @unique
  // JTI del token de reset de contraseña ya consumido (single-use enforcement)
  resetTokenJti   String?   @unique
  // Incrementar para invalidar todas las sesiones activas del usuario
  sessionVersion  Int       @default(0)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  family         Family          @relation(fields: [familyId], references: [id])
  person         Person?         @relation(fields: [personId], references: [id])
  content        Content[]
  importantLinks ImportantLink[]
  auditLogs      AuditLog[]
  representativeManagedUnits ManagedFamilyUnit[]      @relation("ManagedUnitRepresentative")
  accessRules                AccessRule[]
  proposalsMade              PersonUpdateProposal[]   @relation("ProposalProposedBy")
  proposalsReviewed          PersonUpdateProposal[]   @relation("ProposalReviewedBy")
  creationProposalsMade      PersonCreationProposal[] @relation("CreationProposedBy")
  creationProposalsReviewed  PersonCreationProposal[] @relation("CreationReviewedBy")
  notifications              Notification[]
  comments                   Comment[]
  reactions                  Reaction[]
}

model ManagedFamilyUnit {
  id                   String   @id @default(cuid())
  familyId             String
  label                String
  parentAId            String
  parentBId            String?
  primarySurname       String?
  secondarySurname     String?
  representativeUserId String?
  canInviteUsers       Boolean  @default(true)
  canEditPeople        Boolean  @default(true)
  canManageContent     Boolean  @default(true)
  canViewAudit         Boolean  @default(true)
  createdAt            DateTime @default(now())
  createdById          String?

  family               Family   @relation(fields: [familyId], references: [id])
  parentA              Person   @relation("ManagedUnitParentA", fields: [parentAId], references: [id])
  parentB              Person?  @relation("ManagedUnitParentB", fields: [parentBId], references: [id])
  representativeUser   User?    @relation("ManagedUnitRepresentative", fields: [representativeUserId], references: [id])
  affiliatedPersons    Person[] @relation("PersonUnitAffiliation")
}

model AccessRule {
  id             String           @id @default(cuid())
  familyId       String
  userId         String?
  targetPersonId String
  effect         AccessEffect
  permission     AccessPermission
  reason         String?
  createdAt      DateTime         @default(now())
  createdById    String?

  family         Family           @relation(fields: [familyId], references: [id])
  user           User?            @relation(fields: [userId], references: [id])
  targetPerson   Person           @relation("AccessRuleTargetPerson", fields: [targetPersonId], references: [id])

  @@index([familyId, userId, permission])
  @@index([familyId, targetPersonId, permission])
}

// ─────────────────────────────────────────────
// FAMILY CONFIG (límites y módulos por familia)
// ─────────────────────────────────────────────

model FamilyConfig {
  id       String @id @default(cuid())
  familyId String @unique

  // Límites configurables
  maxMediaPerPerson Int @default(100)
  maxFeaturedMedia  Int @default(9)
  maxStories        Int @default(30)
  maxStoryChars     Int @default(10000)
  maxRecipeMedia    Int @default(3)

  // Módulos activables
  moduleStories      Boolean @default(true)
  moduleDiary        Boolean @default(true)
  moduleRecipes      Boolean @default(true)
  moduleMedia        Boolean @default(true)
  moduleObjects      Boolean @default(true)
  moduleLinks        Boolean @default(true)
  moduleAudioVideo   Boolean @default(true)
  moduleExportImport Boolean @default(false)
  moduleSearch       Boolean @default(true)

  family Family @relation(fields: [familyId], references: [id])
}

// ─────────────────────────────────────────────
// AUDIT LOG
// ─────────────────────────────────────────────

model AuditLog {
  id         String   @id @default(cuid())
  familyId   String
  userId     String
  action     String   // "CREATE_PERSON", "EDIT_PERSON", "UPLOAD_MEDIA", etc.
  entityType String   // "Person", "Content", "Media", etc.
  entityId   String
  oldValue   Json?
  newValue   Json?
  createdAt  DateTime @default(now())

  family Family @relation(fields: [familyId], references: [id])
  user   User   @relation(fields: [userId], references: [id])
}

// ─────────────────────────────────────────────
// CONTENT (historias, recetas, objetos, diario, entrevistas, fuentes)
// ─────────────────────────────────────────────

model Content {
  id          String           @id @default(cuid())
  personId    String
  familyId    String
  type        ContentType
  title       String
  body        String?          @db.Text
  visibility  Visibility       @default(FAMILY)
  createdById String
  createdAt   DateTime         @default(now())
  lockedAt    DateTime
  updatedAt   DateTime         @updatedAt

  source      String?
  confidence  ConfidenceLevel?

  // STORY
  approximateDate String?
  authorName      String?

  // RECIPE
  ingredients Json?
  steps       Json?
  notes       String? @db.Text

  // DIARY
  entryDate   DateTime?

  // INTERVIEW
  question    String? @db.Text

  // Soft delete
  deletedAt   DateTime?
  deletedById String?

  person    Person         @relation(fields: [personId], references: [id])
  family    Family         @relation(fields: [familyId], references: [id])
  createdBy User           @relation(fields: [createdById], references: [id])
  media     ContentMedia[]
  comments  Comment[]
  reactions Reaction[]
}

// ─────────────────────────────────────────────
// COMMENT (mensajes de la familia en historias / contenido)
// ─────────────────────────────────────────────

model Comment {
  id          String   @id @default(cuid())
  contentId   String
  familyId    String
  authorId    String                 // User que escribió
  body        String   @db.Text
  // IDs de usuarios mencionados con @nombre — al guardar el comentario se
  // parsea el body y se llena este array. Cada usuario aquí recibe una
  // notificación tipo MENTION_IN_COMMENT al guardar.
  mentionedUserIds String[] @default([])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  deletedAt   DateTime?              // soft delete

  content Content @relation(fields: [contentId], references: [id])
  family  Family  @relation(fields: [familyId], references: [id])
  author  User    @relation(fields: [authorId], references: [id])

  @@index([contentId, createdAt])
}

// ─────────────────────────────────────────────
// REACTION (likes/emociones en historias y fotos)
// Una fila por (usuario, target, tipo). Un usuario puede dejar varias
// reacciones de DIFERENTE tipo en el mismo target — el unique compound
// previene duplicados del mismo tipo. El target es contentId o mediaId
// (nunca los dos a la vez).
// ─────────────────────────────────────────────

model Reaction {
  id        String       @id @default(cuid())
  familyId  String
  userId    String
  type      ReactionType
  contentId String?
  mediaId   String?
  createdAt DateTime     @default(now())

  family  Family   @relation(fields: [familyId], references: [id])
  user    User     @relation(fields: [userId], references: [id])
  content Content? @relation(fields: [contentId], references: [id])
  media   Media?   @relation(fields: [mediaId], references: [id])

  @@unique([userId, contentId, type])
  @@unique([userId, mediaId, type])
  @@index([contentId])
  @@index([mediaId])
}

// ─────────────────────────────────────────────
// MEDIA
// ─────────────────────────────────────────────

enum MediaKind {
  IMAGE
  AUDIO
  VIDEO
}

model Media {
  id           String   @id @default(cuid())
  personId     String
  familyId     String
  url          String                 // original (capeado a 3840px lado mayor; audio/video sin tocar)
  key          String                 // MinIO key del original
  mimeType     String                 // del original
  kind         MediaKind @default(IMAGE)
  durationSec  Int?                   // duración en segundos para audio/video
  posterUrl    String?                // poster (frame extraído) para video
  alt          String?
  caption      String?
  featured     Boolean  @default(false)
  order        Int      @default(0)
  uploadedById String
  createdAt    DateTime @default(now())

  // Variantes WebP generadas en upload (null en filas legacy pre-backfill)
  thumbUrl     String?                // 150px cuadrado, ~10 KB — nodos del árbol
  mediumUrl    String?                // 400px lado mayor, ~50 KB — galería, avatar
  largeUrl     String?                // 1600px lado mayor, ~250 KB — vista expandida
  width        Int?                   // dimensiones reales del original (post-cap)
  height       Int?

  person       Person         @relation(fields: [personId], references: [id])
  family       Family         @relation(fields: [familyId], references: [id])
  contentMedia ContentMedia[]
  reactions    Reaction[]
}

// ─────────────────────────────────────────────
// CONTENT ↔ MEDIA (pivot)
// ─────────────────────────────────────────────

model ContentMedia {
  contentId String
  mediaId   String
  order     Int    @default(0)

  content Content @relation(fields: [contentId], references: [id])
  media   Media   @relation(fields: [mediaId], references: [id])

  @@id([contentId, mediaId])
}

// ─────────────────────────────────────────────
// IMPORTANT LINK (relaciones no familiares)
// ─────────────────────────────────────────────

// ─────────────────────────────────────────────
// PERSON UPDATE PROPOSAL
// ─────────────────────────────────────────────

model PersonUpdateProposal {
  id              String         @id @default(cuid())
  familyId        String
  personId        String
  proposedById    String
  status          ProposalStatus @default(PENDING)
  reviewedById    String?
  reviewedAt      DateTime?
  rejectionReason String?

  // Campos propuestos — null significa "no cambia este campo"
  firstName     String?
  middleName    String?
  lastName      String?
  gender        Gender?
  birthDate     DateTime?
  deathDate     DateTime?
  birthPlace    String?
  bio           String?

  currentValues Json
  createdAt     DateTime @default(now())

  family     Family  @relation(fields: [familyId], references: [id])
  person     Person  @relation("ProposalPerson", fields: [personId], references: [id])
  proposedBy User    @relation("ProposalProposedBy", fields: [proposedById], references: [id])
  reviewedBy User?   @relation("ProposalReviewedBy", fields: [reviewedById], references: [id])

  @@index([familyId, status])
  @@index([personId, status])
}

// ─────────────────────────────────────────────
// PERSON CREATION PROPOSAL (sugerencias de personas nuevas por MEMBER)
// ─────────────────────────────────────────────

model PersonCreationProposal {
  id              String         @id @default(cuid())
  familyId        String
  proposedById    String
  status          ProposalStatus @default(PENDING)
  reviewedById    String?
  reviewedAt      DateTime?
  rejectionReason String?

  firstName  String
  lastName   String?
  middleName String?
  gender     Gender?
  birthDate  DateTime?
  deathDate  DateTime?
  birthPlace String?
  nodeKind   PersonKind @default(PERSON)
  notes      String?    @db.Text
  fatherId   String?
  motherId   String?

  createdAt DateTime @default(now())

  family     Family  @relation(fields: [familyId], references: [id])
  proposedBy User    @relation("CreationProposedBy",  fields: [proposedById], references: [id])
  reviewedBy User?   @relation("CreationReviewedBy",  fields: [reviewedById], references: [id])
  father     Person? @relation("CreationProposalFather", fields: [fatherId], references: [id])
  mother     Person? @relation("CreationProposalMother", fields: [motherId], references: [id])

  @@index([familyId, status])
}

// ─────────────────────────────────────────────
// NOTIFICATION
// ─────────────────────────────────────────────

model Notification {
  id        String           @id @default(cuid())
  userId    String
  familyId  String
  type      NotificationType
  title     String
  body      String?
  href      String?
  read      Boolean          @default(false)
  createdAt DateTime         @default(now())

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  family Family @relation(fields: [familyId], references: [id], onDelete: Cascade)

  @@index([userId, read])
  @@index([userId, createdAt])
}

// ─────────────────────────────────────────────
model ImportantLink {
  id              String           @id @default(cuid())
  personId        String
  familyId        String
  relatedPersonId String?
  externalName    String?
  label           String
  notes           String?          @db.Text
  source          String?
  confidence      ConfidenceLevel?
  visibility      Visibility       @default(FAMILY)
  createdById     String
  lockedAt        DateTime
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  person        Person  @relation("PersonLinks", fields: [personId], references: [id])
  relatedPerson Person? @relation("ImportantLinkTarget", fields: [relatedPersonId], references: [id])
  family        Family  @relation(fields: [familyId], references: [id])
  createdBy     User    @relation(fields: [createdById], references: [id])
}
