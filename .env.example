# ── Database ───────────────────────────────────────────────────────────────────
# Full PostgreSQL connection string (used in local dev)
DATABASE_URL="postgresql://genome_tree:PASSWORD@localhost:5432/genome_tree"
# Password for the genome_tree DB user (used by Docker Compose)
POSTGRES_PASSWORD="change_this"

# ── Sessions ────────────────────────────────────────────────────────────────────
# Secret key used to sign JWT session tokens. Generate with: openssl rand -base64 32
SESSION_SECRET="change_this_to_a_long_random_string"

# ── Public hostname ─────────────────────────────────────────────────────────────
# Domain where the app is served (e.g. arbol.example.com)
APP_HOSTNAME=arbol.example.com

# ── MinIO (photo/media storage) ─────────────────────────────────────────────────
MINIO_ROOT_USER="admin"
MINIO_ROOT_PASSWORD="change_this"

# Public URL the browser uses to load images.
# Production: https://${APP_HOSTNAME}/media  (Nginx proxies from MinIO)
# Development: leave empty → uses http://localhost:9000 directly
MINIO_PUBLIC_URL=""

# For local development with MinIO running outside Docker:
MINIO_ENDPOINT="localhost"
MINIO_PORT="9000"
MINIO_BUCKET="genome-tree"

# ── Cloudflare Tunnel ───────────────────────────────────────────────────────────
# Token from Zero Trust → Networks → Tunnels. Only needed in production.
CLOUDFLARE_TUNNEL_TOKEN=""

# ── Quick MinIO for local dev (no installation required) ───────────────────────
# docker run -p 9000:9000 -p 9001:9001 \
#   -e MINIO_ROOT_USER=admin -e MINIO_ROOT_PASSWORD=devpassword \
#   minio/minio server /data --console-address ":9001"
